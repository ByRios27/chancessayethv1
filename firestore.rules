rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authUid() {
      return signedIn() ? request.auth.uid : '';
    }

    function authEmail() {
      return signedIn() && request.auth.token.get('email', null) is string
        ? request.auth.token.get('email', '').lower()
        : '';
    }

    function userDocByUid() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
        : null;
    }

    function userDocByEmail() {
      return signedIn() && authEmail() != ''
        ? get(/databases/$(database)/documents/users/$(authEmail()))
        : null;
    }

    function hasUserDocByUid() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDocByEmail() {
      return signedIn() &&
        authEmail() != '' &&
        exists(/databases/$(database)/documents/users/$(authEmail()));
    }

    function currentUserData() {
      return hasUserDocByUid()
        ? userDocByUid().data
        : hasUserDocByEmail()
          ? userDocByEmail().data
          : {};
    }

    function role() {
      return signedIn()
        ? (
          currentUserData().get('role', '') is string
            ? currentUserData().get('role', '').lower()
            : (request.auth.token.get('role', '') is string
              ? request.auth.token.get('role', '').lower()
              : '')
        )
        : '';
    }

    function userStatus() {
      return signedIn()
        ? (
          currentUserData().get('status', 'active') is string
            ? currentUserData().get('status', 'active').lower()
            : 'active'
        )
        : '';
    }

    function profileEmail() {
      return (currentUserData().get('email', '') is string && currentUserData().get('email', '') != '')
        ? currentUserData().get('email', '').lower()
        : authEmail();
    }

    function profileSellerId() {
      return currentUserData().get('sellerId', '') is string
        ? currentUserData().get('sellerId', '')
        : '';
    }

    function ownerCeoEmail() {
      return 'zsayeth09@gmail.com';
    }

    function ownerCeoSellerId() {
      return 'ceo01';
    }

    function profileIsPrimaryCeo() {
      return currentUserData().get('isPrimaryCeo', false) == true;
    }

    function profileHasOwnerSellerId() {
      return profileSellerId().lower() == ownerCeoSellerId();
    }

    function profileHasOwnerEmail() {
      return profileEmail() == ownerCeoEmail();
    }

    function profileHasCeoRole() {
      return role() == 'ceo' || role() == 'owner';
    }

    function isOwnerCeo() {
      return signedIn() && (
        authEmail() == ownerCeoEmail() ||
        profileHasOwnerEmail() ||
        request.auth.token.get('isPrimaryCeo', false) == true ||
        profileIsPrimaryCeo() ||
        profileHasOwnerSellerId()
      );
    }

    function isActiveUser() {
      return signedIn() && userStatus() != 'inactive';
    }

    function isCeo() {
      return isOwnerCeo() || (isActiveUser() && (role() == 'ceo' || role() == 'owner'));
    }

    function isAdmin() {
      return role() == 'admin' && isActiveUser();
    }

    function isSeller() {
      return role() == 'seller' && isActiveUser();
    }

    function isOwnerOrAdmin() {
      return isOwnerCeo() || isCeo() || isAdmin();
    }

    function isPrimaryCeo() {
      return isOwnerCeo() || (isCeo() && (
        request.auth.token.get('isPrimaryCeo', false) == true ||
        profileEmail() == 'zsayeth09@gmail.com'
      ));
    }

    function identityMatches(value) {
      return signedIn() &&
        value is string &&
        value != '' &&
        (
          value == authUid() ||
          value.lower() == authEmail() ||
          value.lower() == profileEmail() ||
          value.lower() == profileSellerId().lower()
        );
    }

    function isOwner(email) {
      return signedIn() && authEmail() == email.lower();
    }

    function isOwnUserDoc(userId) {
      return signedIn() && authEmail() != '' && authEmail() == userId.lower();
    }

    function ticketBelongsToCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('sellerId', '')) ||
          identityMatches(data.get('sellerEmail', '')) ||
          identityMatches(data.get('userId', '')) ||
          identityMatches(data.get('userEmail', '')) ||
          identityMatches(data.get('createdBy', '')) ||
          identityMatches(data.get('createdByEmail', ''))
        );
    }

    function injectionBelongsToCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('sellerId', '')) ||
          identityMatches(data.get('userEmail', '')) ||
          identityMatches(data.get('createdBy', '')) ||
          identityMatches(data.get('addedBy', '')) ||
          identityMatches(data.get('createdByEmail', '')) ||
          identityMatches(data.get('createdBySellerId', '')) ||
          identityMatches(data.get('actorEmail', '')) ||
          identityMatches(data.get('actorSellerId', '')) ||
          identityMatches(data.get('updatedByEmail', ''))
        );
    }

    function injectionTargetBelongsToCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('sellerId', '')) ||
          identityMatches(data.get('userEmail', ''))
        );
    }

    function injectionTargetsOnlyCurrentUser(data) {
      return signedIn() &&
        (
          !data.keys().hasAny(['sellerId']) ||
          identityMatches(data.get('sellerId', ''))
        ) &&
        (
          !data.keys().hasAny(['userEmail']) ||
          identityMatches(data.get('userEmail', ''))
        );
    }

    function injectionCreatedByCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('createdBy', '')) ||
          identityMatches(data.get('addedBy', '')) ||
          identityMatches(data.get('createdByEmail', '')) ||
          identityMatches(data.get('createdBySellerId', '')) ||
          identityMatches(data.get('actorEmail', '')) ||
          identityMatches(data.get('actorSellerId', ''))
        );
    }

    function injectionHasAuthor(data) {
      return
        (data.get('createdBy', '') is string && data.get('createdBy', '') != '') ||
        (data.get('addedBy', '') is string && data.get('addedBy', '') != '') ||
        (data.get('createdByEmail', '') is string && data.get('createdByEmail', '') != '') ||
        (data.get('createdBySellerId', '') is string && data.get('createdBySellerId', '') != '') ||
        (data.get('actorEmail', '') is string && data.get('actorEmail', '') != '') ||
        (data.get('actorSellerId', '') is string && data.get('actorSellerId', '') != '');
    }

    function injectionAmountIsValid(data) {
      return data.get('amount', -1) is number && data.get('amount', -1) >= 0;
    }

    function settlementBelongsToCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('sellerId', '')) ||
          identityMatches(data.get('userEmail', '')) ||
          identityMatches(data.get('liquidatedBy', ''))
        );
    }

    function archiveBelongsToCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('archivedBy', '')) ||
          identityMatches(data.get('userEmail', ''))
        );
    }

    function auditEventBelongsToCurrentUser(data) {
      return signedIn() &&
        (
          identityMatches(data.get('actorEmail', '')) ||
          identityMatches(data.get('actorSellerId', '')) ||
          identityMatches(data.get('targetEmail', '')) ||
          identityMatches(data.get('targetSellerId', ''))
        );
    }

    function alertTargetsCurrentUser(data) {
      return signedIn() && (
        data.get('global', false) == true ||
        (
          data.get('targetUserEmail', '') is string &&
          data.get('targetUserEmail', '').lower() == profileEmail()
        ) ||
        (
          data.get('targetRole', '') is string &&
          data.get('targetRole', '').lower() == role()
        )
      );
    }

    function isPrimaryOwnerEmail(email) {
      return email.lower() == 'zsayeth09@gmail.com';
    }

    function canBootstrapPrimaryOwnerCreate(userId) {
      return isOwnUserDoc(userId) &&
        isPrimaryOwnerEmail(userId) &&
        !exists(/databases/$(database)/documents/users/$(userId)) &&
        request.resource.data.get('email', '').lower() == userId.lower() &&
        request.resource.data.get('name', '') is string &&
        request.resource.data.get('role', '') == 'ceo' &&
        request.resource.data.get('status', '') == 'active' &&
        request.resource.data.get('isPrimaryCeo', false) == true &&
        request.resource.data.get('commissionRate', -1) is number &&
        request.resource.data.get('currentDebt', -1) is number &&
        request.resource.data.get('canLiquidate', false) is bool;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role']) &&
        data.email is string &&
        data.email.size() < 120 &&
        data.name is string &&
        data.name.size() < 120 &&
        data.role in ['ceo', 'admin', 'seller'] &&
        (
          !data.keys().hasAny(['status']) ||
          data.get('status', 'active') in ['active', 'inactive']
        ) &&
        (
          !data.keys().hasAny(['isPrimaryCeo']) ||
          data.get('isPrimaryCeo', false) is bool
        );
    }

    function createdCeoHasValidPrimaryFlag() {
      return request.resource.data.get('role', '') != 'ceo' ||
        request.resource.data.get('isPrimaryCeo', false) == false ||
        isPrimaryCeo();
    }

    function updatedUserKeepsPrimaryFlag() {
      return request.resource.data.get('isPrimaryCeo', false) == resource.data.get('isPrimaryCeo', false);
    }

    function targetUserIsProtectedOwner() {
      return resource.data.get('isPrimaryCeo', false) == true ||
        resource.data.get('email', '').lower() == ownerCeoEmail() ||
        resource.data.get('sellerId', '').lower() == ownerCeoSellerId();
    }

    function createdByCurrentUser(data) {
      return identityMatches(data.get('createdByEmail', '')) ||
        identityMatches(data.get('createdBy', '')) ||
        identityMatches(data.get('createdBySellerId', ''));
    }

    function userCreateHasAuthor(data) {
      return identityMatches(data.get('createdByEmail', '')) &&
        data.get('createdByRole', '').lower() == role() &&
        (
          !data.keys().hasAny(['createdBy']) ||
          data.get('createdBy', '') == '' ||
          identityMatches(data.get('createdBy', ''))
        ) &&
        (
          !data.keys().hasAny(['createdBySellerId']) ||
          data.get('createdBySellerId', '') == '' ||
          identityMatches(data.get('createdBySellerId', ''))
        );
    }

    function userAuthorFieldsUnchanged() {
      return request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '') &&
        request.resource.data.get('createdByEmail', '') == resource.data.get('createdByEmail', '') &&
        request.resource.data.get('createdByRole', '') == resource.data.get('createdByRole', '') &&
        request.resource.data.get('createdBySellerId', '') == resource.data.get('createdBySellerId', '') &&
        request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null);
    }

    function ownerProfileUpdateIsSafe() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'preferredChancePrice', 'sessionTimeoutMinutes', 'commissionRate']) &&
        request.resource.data.get('email', '').lower() == resource.data.get('email', '').lower() &&
        request.resource.data.get('role', '') == resource.data.get('role', '') &&
        request.resource.data.get('status', '') == resource.data.get('status', '') &&
        (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['commissionRate']) ||
          (
            request.resource.data.get('commissionRate', -1) is number &&
            request.resource.data.get('commissionRate', -1) >= 0
          )
        ) &&
        request.resource.data.get('isPrimaryCeo', false) == resource.data.get('isPrimaryCeo', false);
    }

    function canManageUserCreate() {
      return signedIn() && (
        (
          isCeo() &&
          isValidUser(request.resource.data) &&
          createdCeoHasValidPrimaryFlag() &&
          userCreateHasAuthor(request.resource.data)
        ) ||
        (isAdmin() && isValidUser(request.resource.data) && request.resource.data.get('role', '') == 'seller' && userCreateHasAuthor(request.resource.data))
      );
    }

    function canManageUserUpdate() {
      return signedIn() && (
        (
          isCeo() &&
          !targetUserIsProtectedOwner() &&
          updatedUserKeepsPrimaryFlag()
        ) ||
        (
          isAdmin() &&
          resource.data.get('role', '') == 'seller' &&
          request.resource.data.get('role', '') == 'seller' &&
          createdByCurrentUser(resource.data) &&
          userAuthorFieldsUnchanged() &&
          updatedUserKeepsPrimaryFlag()
        )
      );
    }

    function canManageUserDelete() {
      return signedIn() && (
        (isCeo() && !targetUserIsProtectedOwner()) ||
        (isAdmin() && resource.data.get('role', '') == 'seller' && createdByCurrentUser(resource.data))
      );
    }

    match /users/{email} {
      allow read: if isOwnerCeo() || (signedIn() && (isOwnUserDoc(email) || isOwnerOrAdmin()));
      allow create: if isOwnerCeo() || canManageUserCreate() || canBootstrapPrimaryOwnerCreate(email);
      allow update: if isOwnerCeo() || canManageUserUpdate() || (isOwnUserDoc(email) && ownerProfileUpdateIsSafe());
      allow delete: if isOwnerCeo() || (canManageUserDelete() && (resource.data.get('role', '') != 'ceo' || isCeo()));
    }

    match /userProvisioning/{email} {
      allow read: if isOwnerCeo() || (signedIn() && (isOwner(email) || isOwnerOrAdmin()));
      allow create: if isOwnerCeo() || (signedIn() && (isCeo() || (isAdmin() && request.resource.data.get('role', '') == 'seller')));
      allow update: if isOwnerCeo() || (signedIn() && (isCeo() || (isAdmin() && resource.data.get('role', '') == 'seller' && request.resource.data.get('role', '') == 'seller')));
      allow delete: if isOwnerCeo() || (signedIn() && (isCeo() || (isAdmin() && resource.data.get('role', '') == 'seller')));
    }

    match /lotteries/{lotteryId} {
      allow read: if isOwnerCeo() || signedIn();
      allow create, delete: if isOwnerCeo() || isCeo();
      allow update: if isOwnerCeo() || isCeo() || (
        isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active']) &&
        request.resource.data.get('active', false) is bool
      );
    }

    match /tickets/{ticketId} {
      allow read: if isOwnerCeo() || (signedIn() && (isOwnerOrAdmin() || ticketBelongsToCurrentUser(resource.data)));

      allow create: if isOwnerCeo() || (signedIn() && (
        isOwnerOrAdmin() ||
        ticketBelongsToCurrentUser(request.resource.data)
      ));

      allow update: if
        isOwnerCeo() ||
        isOwnerOrAdmin() ||
        (
          signedIn() &&
          ticketBelongsToCurrentUser(resource.data) &&
          ticketBelongsToCurrentUser(request.resource.data)
        );

      allow delete: if
        isOwnerCeo() ||
        isOwnerOrAdmin() ||
        (
          signedIn() &&
          ticketBelongsToCurrentUser(resource.data)
        );
    }

    match /results/{resultId} {
      allow read: if isOwnerCeo() || signedIn();
      allow write: if isOwnerCeo() || isOwnerOrAdmin();
    }

    match /injections/{injectionId} {
      allow read: if isOwnerCeo() || (signedIn() && (
        isOwnerOrAdmin() ||
        injectionTargetBelongsToCurrentUser(resource.data) ||
        injectionCreatedByCurrentUser(resource.data)
      ));
      allow create: if
        isOwnerCeo() ||
        (
          signedIn() &&
          injectionAmountIsValid(request.resource.data) &&
          injectionCreatedByCurrentUser(request.resource.data) &&
          (
            isOwnerOrAdmin() ||
            (isSeller() && injectionTargetsOnlyCurrentUser(request.resource.data))
          )
        );
      allow update: if
        isOwnerCeo() ||
        (signedIn() && (
          (
            injectionAmountIsValid(request.resource.data) &&
            injectionCreatedByCurrentUser(resource.data) &&
            injectionCreatedByCurrentUser(request.resource.data) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'updatedAt', 'updatedByEmail'])
          ) ||
          (
            injectionAmountIsValid(request.resource.data) &&
            isPrimaryCeo() &&
            !injectionHasAuthor(resource.data) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'updatedAt', 'updatedByEmail'])
          ) ||
          (
            isOwnerOrAdmin() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['liquidated', 'settlementId'])
          )
        ));
      allow delete: if
        isOwnerCeo() ||
        (signedIn() && (
          injectionCreatedByCurrentUser(resource.data) ||
          (isPrimaryCeo() && !injectionHasAuthor(resource.data))
        ));
    }

    match /settlements/{settlementId} {
      allow read: if isOwnerCeo() || (signedIn() && (isOwnerOrAdmin() || settlementBelongsToCurrentUser(resource.data)));
      allow write: if isOwnerCeo() || isOwnerOrAdmin();
    }

    match /daily_archives/{archiveId} {
      allow read: if isOwnerCeo() || (signedIn() && (isOwnerOrAdmin() || archiveBelongsToCurrentUser(resource.data)));
      allow create: if isOwnerCeo() || isOwnerOrAdmin();
      allow update: if isOwnerCeo() || isOwnerOrAdmin();
      allow delete: if isOwnerCeo() || isCeo();
    }

    match /daily_audit_logs/{logDate}/events/{eventId} {
      allow read: if isOwnerCeo() || (signedIn() && (isOwnerOrAdmin() || auditEventBelongsToCurrentUser(resource.data)));
      allow create: if
        isOwnerCeo() ||
        (
          signedIn() &&
          isOwnerOrAdmin() &&
          identityMatches(request.resource.data.get('actorEmail', '')) &&
          request.resource.data.get('actorRole', '') in ['ceo', 'admin']
        );
      allow update, delete: if false;
    }

    match /app_alerts/{alertId} {
      allow read: if isOwnerCeo() || alertTargetsCurrentUser(resource.data);
      allow create: if isOwnerCeo() || (signedIn() &&
        isOwnerOrAdmin() &&
        identityMatches(request.resource.data.get('createdByEmail', '')) &&
        request.resource.data.get('createdByRole', '') in ['ceo', 'admin']);
      allow update: if isOwnerCeo() || (alertTargetsCurrentUser(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if isOwnerCeo() || isCeo();
    }

    match /settings/global {
      allow read: if isOwnerCeo() || signedIn();
      allow write: if isOwnerCeo() || isCeo();
    }

    match /public/connectivity {
      allow read, write: if isOwnerCeo() || signedIn();
    }

    match /test/connection {
      allow read, write: if isOwnerCeo() || signedIn();
    }

    match /{document=**} {
      allow read, write: if isOwnerCeo();
    }
  }
}
