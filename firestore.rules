rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: email (lowercase)
    // Fields: email, name, role (ceo, admin, seller), sellerId, commissionRate, etc.
    //
    // Collection: lotteries
    // Document ID: auto-generated
    // Fields: name, drawTime, closingTime, isFourDigits, active
    //
    // Collection: tickets
    // Document ID: auto-generated
    // Fields: bets, totalAmount, timestamp, sellerId, sellerEmail, status, etc.
    //
    // Collection: results
    // Document ID: auto-generated
    // Fields: lotteryName, date, firstPrize, secondPrize, thirdPrize, timestamp
    //
    // Collection: injections
    // Document ID: auto-generated
    // Fields: userEmail, amount, type, date, timestamp, addedBy, liquidated
    //
    // Collection: settlements
    // Document ID: auto-generated
    // Fields: userEmail, date, totalSales, totalCommission, totalPrizes, netProfit, etc.
    //
    // Collection: settings
    // Document ID: global
    // Fields: chancePrices, specialChanceMultipliers, palesEnabled, etc.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserEmail() {
      return request.auth.token.get('email', '').lower();
    }

    function getUserData(email) {
      return exists(/databases/$(database)/documents/users/$(email.lower())) 
        ? get(/databases/$(database)/documents/users/$(email.lower())).data 
        : null;
    }

    function getProvisioningData(email) {
      return exists(/databases/$(database)/documents/userProvisioning/$(email.lower()))
        ? get(/databases/$(database)/documents/userProvisioning/$(email.lower())).data
        : null;
    }

    function isCeo() {
      return isAuthenticated() && currentUserEmail() == 'zsayeth09@gmail.com';
    }

    function isAdmin() {
      return isAuthenticated() && (
        isCeo() ||
        (getUserData(currentUserEmail()) != null && getUserData(currentUserEmail()).role == 'admin')
      );
    }

    function canReadAllSalesData() {
      return isCeo() || isAdmin();
    }

    function isOwner(email) {
      return isAuthenticated() && currentUserEmail() == email.lower();
    }

    function isProvisionedOwner(email) {
      return isOwner(email) && getProvisioningData(email) != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role']) &&
             data.email is string && data.email.size() < 100 &&
             data.name is string && data.name.size() < 100 &&
             data.role in ['ceo', 'admin', 'seller'];
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['bets', 'totalAmount', 'timestamp', 'sellerId', 'sellerEmail', 'status']) &&
             data.bets is list &&
             data.totalAmount is number &&
             data.sellerEmail is string &&
             data.status in ['active', 'cancelled', 'winner'];
    }

    function ownerProfileUpdateIsSafe() {
      return request.resource.data.get('email', '') == resource.data.get('email', '') &&
             request.resource.data.get('name', '') == resource.data.get('name', '') &&
             request.resource.data.get('role', '') == resource.data.get('role', '') &&
             request.resource.data.get('commissionRate', 0) == resource.data.get('commissionRate', 0) &&
             request.resource.data.get('status', '') == resource.data.get('status', '') &&
             request.resource.data.get('canLiquidate', false) == resource.data.get('canLiquidate', false) &&
             request.resource.data.get('currentDebt', 0) == resource.data.get('currentDebt', 0) &&
             request.resource.data.get('sellerId', '') == resource.data.get('sellerId', '') &&
             request.resource.data.get('sessionTimeoutMinutes', 60) == resource.data.get('sessionTimeoutMinutes', 60);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{email} {
      allow read: if isAuthenticated() && (isOwner(email) || canReadAllSalesData());
      allow create: if isAuthenticated() && (
        isCeo() || 
        (isAdmin() && request.resource.data.get('role', '') == 'seller') || 
        (isProvisionedOwner(email) && isValidUser(request.resource.data) && request.resource.data == getProvisioningData(email))
      );
      allow update: if isAuthenticated() && (
        isCeo() || 
        (isAdmin() && resource.data.get('role', '') == 'seller' && request.resource.data.get('role', '') == 'seller') || 
        (isOwner(email) && ownerProfileUpdateIsSafe())
      );
      allow delete: if isCeo();
    }

    match /userProvisioning/{email} {
      allow read: if isAuthenticated() && (isOwner(email) || canReadAllSalesData());
      allow create: if isAuthenticated() && (
        isCeo() ||
        (isAdmin() && request.resource.data.get('role', '') == 'seller')
      );
      allow update: if isAuthenticated() && (
        isCeo() ||
        (isAdmin() && resource.data.get('role', '') == 'seller' && request.resource.data.get('role', '') == 'seller')
      );
      allow delete: if isAuthenticated() && (
        isCeo() ||
        (isAdmin() && resource.data.get('role', '') == 'seller')
      );
    }

    match /lotteries/{lotteryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (canReadAllSalesData() || resource.data.sellerId == request.auth.uid || resource.data.sellerEmail == currentUserEmail());
      
      allow create: if isAuthenticated() && (isCeo() || isAdmin() || request.resource.data.sellerId == request.auth.uid);
      
      allow update: if isCeo() || isAdmin() || (
        isAuthenticated() &&
        resource.data.status == 'active' &&
        resource.data.get('liquidated', false) == false &&
        (resource.data.sellerId == request.auth.uid || resource.data.sellerEmail == currentUserEmail()) &&
        request.resource.data.sellerId == resource.data.sellerId &&
        request.resource.data.sellerEmail == resource.data.sellerEmail &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.get('liquidated', false) == resource.data.get('liquidated', false) &&
        request.resource.data.get('settlementId', null) == resource.data.get('settlementId', null) &&
        request.resource.data.timestamp == resource.data.timestamp
      );
      
      allow delete: if isAuthenticated() &&
        (
          isCeo() ||
          (
            resource.data.status == 'active' &&
            resource.data.get('liquidated', false) == false &&
            (resource.data.sellerId == request.auth.uid || resource.data.sellerEmail == currentUserEmail())
          )
        );
    }

    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /injections/{injectionId} {
      allow read: if isAuthenticated() && (canReadAllSalesData() || resource.data.userEmail == currentUserEmail());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isCeo();
    }

    match /settlements/{settlementId} {
      allow read: if isAuthenticated() && (canReadAllSalesData() || resource.data.userEmail == currentUserEmail());
      allow write: if isAdmin();
    }

    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isCeo();
    }

    match /public/connectivity {
      allow read, write: if true;
    }

    match /test/connection {
      allow read, write: if true;
    }
  }
}
