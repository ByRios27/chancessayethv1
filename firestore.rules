rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserEmail() {
      return isAuthenticated() && request.auth.token.get('email', null) != null
        ? request.auth.token.get('email', '').lower()
        : null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function currentUserExists() {
      return isAuthenticated() &&
        currentUserEmail() != null &&
        exists(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function currentUserRole() {
      return currentUserExists()
        ? currentUserDoc().data.get('role', '')
        : request.auth.token.get('role', '');
    }

    function currentUserStatus() {
      return currentUserExists()
        ? currentUserDoc().data.get('status', '')
        : '';
    }

    function isActiveUser() {
      return currentUserStatus() == 'active';
    }

    function isCeo() {
      return currentUserRole() == 'ceo' && isActiveUser();
    }

    function isAdmin() {
      return currentUserRole() == 'admin' && isActiveUser();
    }

    function isSeller() {
      return currentUserRole() == 'seller' && isActiveUser();
    }

    function isPrimaryCeo() {
      return isCeo() && (
        request.auth.token.get('isPrimaryCeo', false) == true ||
        currentUserEmail() == 'zsayeth09@gmail.com'
      );
    }

    function canReadAllSalesData() {
      return isCeo() || isAdmin();
    }

    function isOwner(email) {
      return isAuthenticated() && currentUserEmail() == email.lower();
    }

    function isOwnUserDoc(userId) {
      return isAuthenticated() && currentUserEmail() != null && currentUserEmail() == userId.lower();
    }

    function isPrimaryOwnerEmail(email) {
      return email.lower() == 'zsayeth09@gmail.com';
    }

    function canBootstrapPrimaryOwnerCreate(userId) {
      return isOwnUserDoc(userId) &&
        isPrimaryOwnerEmail(userId) &&
        !exists(/databases/$(database)/documents/users/$(userId)) &&
        request.resource.data.get('email', '').lower() == userId.lower() &&
        request.resource.data.get('name', '') is string &&
        request.resource.data.get('role', '') == 'ceo' &&
        request.resource.data.get('status', '') == 'active' &&
        request.resource.data.get('isPrimaryCeo', false) == true &&
        request.resource.data.get('commissionRate', -1) is number &&
        request.resource.data.get('currentDebt', -1) is number &&
        request.resource.data.get('canLiquidate', false) is bool;
    }

    function isSellerTicketOwner() {
      return isAuthenticated() &&
        (
          resource.data.get('sellerId', '') == request.auth.uid ||
          resource.data.get('sellerEmail', '').lower() == currentUserEmail()
        );
    }

    function incomingTicketBelongsToCurrentUser() {
      return isAuthenticated() &&
        request.resource.data.get('sellerId', '') == request.auth.uid &&
        request.resource.data.get('sellerEmail', '').lower() == currentUserEmail();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role']) &&
        data.email is string &&
        data.email.size() < 120 &&
        data.name is string &&
        data.name.size() < 120 &&
        data.role in ['ceo', 'admin', 'seller'] &&
        (
          !data.keys().hasAny(['status']) ||
          data.get('status', 'active') in ['active', 'inactive']
        ) &&
        (
          !data.keys().hasAny(['isPrimaryCeo']) ||
          data.get('isPrimaryCeo', false) is bool
        );
    }

    function createdCeoHasValidPrimaryFlag() {
      return request.resource.data.get('role', '') != 'ceo' ||
        request.resource.data.get('isPrimaryCeo', false) == false ||
        isPrimaryCeo();
    }

    function updatedUserKeepsPrimaryFlag() {
      return request.resource.data.get('isPrimaryCeo', false) == resource.data.get('isPrimaryCeo', false);
    }

    function ownerProfileUpdateIsSafe() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'preferredChancePrice', 'sessionTimeoutMinutes', 'commissionRate']) &&
        request.resource.data.get('email', '').lower() == resource.data.get('email', '').lower() &&
        request.resource.data.get('role', '') == resource.data.get('role', '') &&
        request.resource.data.get('status', '') == resource.data.get('status', '') &&
        (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['commissionRate']) ||
          (
            request.resource.data.get('commissionRate', -1) is number &&
            request.resource.data.get('commissionRate', -1) >= 0
          )
        ) &&
        request.resource.data.get('isPrimaryCeo', false) == resource.data.get('isPrimaryCeo', false);
    }

    function canManageUserCreate() {
      return isAuthenticated() && (
        (
          isCeo() &&
          isValidUser(request.resource.data) &&
          createdCeoHasValidPrimaryFlag()
        ) ||
        (isAdmin() && isValidUser(request.resource.data) && request.resource.data.get('role', '') == 'seller')
      );
    }

    function canManageUserUpdate() {
      return isAuthenticated() && (
        (
          isCeo() &&
          updatedUserKeepsPrimaryFlag()
        ) ||
        (
          isAdmin() &&
          resource.data.get('role', '') == 'seller' &&
          request.resource.data.get('role', '') == 'seller' &&
          updatedUserKeepsPrimaryFlag()
        )
      );
    }

    function canManageUserDelete() {
      return isAuthenticated() && (
        isCeo() ||
        (isAdmin() && resource.data.get('role', '') == 'seller')
      );
    }

    match /users/{email} {
      allow read: if isAuthenticated() && (isOwnUserDoc(email) || canReadAllSalesData());
      allow create: if canManageUserCreate() || canBootstrapPrimaryOwnerCreate(email);
      allow update: if canManageUserUpdate() || (isOwnUserDoc(email) && ownerProfileUpdateIsSafe());
      allow delete: if canManageUserDelete() && (resource.data.get('role', '') != 'ceo' || isCeo());
    }

    match /userProvisioning/{email} {
      allow read: if isAuthenticated() && (isOwner(email) || canReadAllSalesData());
      allow create: if isAuthenticated() && (isCeo() || (isAdmin() && request.resource.data.get('role', '') == 'seller'));
      allow update: if isAuthenticated() && (isCeo() || (isAdmin() && resource.data.get('role', '') == 'seller' && request.resource.data.get('role', '') == 'seller'));
      allow delete: if isAuthenticated() && (isCeo() || (isAdmin() && resource.data.get('role', '') == 'seller'));
    }

    match /lotteries/{lotteryId} {
      allow read: if isAuthenticated();
      allow write: if isCeo() || isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (canReadAllSalesData() || isSellerTicketOwner());

      allow create: if isAuthenticated() && (isCeo() || isAdmin() || incomingTicketBelongsToCurrentUser());

      allow update: if
        isCeo() ||
        isAdmin() ||
        (
          isAuthenticated() &&
          isSellerTicketOwner() &&
          resource.data.get('status', '') == 'active' &&
          resource.data.get('liquidated', false) == false &&
          request.resource.data.get('sellerId', '') == resource.data.get('sellerId', '') &&
          request.resource.data.get('sellerEmail', '').lower() == resource.data.get('sellerEmail', '').lower() &&
          request.resource.data.get('status', '') == resource.data.get('status', '') &&
          request.resource.data.get('liquidated', false) == resource.data.get('liquidated', false) &&
          request.resource.data.get('settlementId', null) == resource.data.get('settlementId', null) &&
          request.resource.data.get('timestamp', null) == resource.data.get('timestamp', null)
        );

      allow delete: if
        isCeo() ||
        (
          isAuthenticated() &&
          isSellerTicketOwner() &&
          resource.data.get('status', '') == 'active' &&
          resource.data.get('liquidated', false) == false
        );
    }

    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isCeo() || isAdmin();
    }

    match /injections/{injectionId} {
      allow read: if isAuthenticated() && (canReadAllSalesData() || resource.data.get('userEmail', '').lower() == currentUserEmail());
      allow create: if
        (isCeo() || isAdmin()) &&
        request.resource.data.get('createdByEmail', '').lower() == currentUserEmail();
      allow update: if
        (isCeo() || isAdmin()) && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['liquidated', 'settlementId', 'updatedAt', 'updatedByEmail'])
          ) ||
          (
            (
              resource.data.get('createdByEmail', '').lower() == currentUserEmail() ||
              resource.data.get('createdBy', '') == request.auth.uid ||
              (resource.data.get('createdByEmail', '') == '' && resource.data.get('createdBy', '') == '' && isPrimaryCeo())
            ) &&
            request.resource.data.get('createdByEmail', '').lower() == resource.data.get('createdByEmail', '').lower() &&
            request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          )
        );
      allow delete: if
        (isCeo() || isAdmin()) &&
        (
          resource.data.get('createdByEmail', '').lower() == currentUserEmail() ||
          resource.data.get('createdBy', '') == request.auth.uid ||
          (resource.data.get('createdByEmail', '') == '' && resource.data.get('createdBy', '') == '' && isPrimaryCeo())
        );
    }

    match /settlements/{settlementId} {
      allow read: if isAuthenticated() && (canReadAllSalesData() || resource.data.get('userEmail', '').lower() == currentUserEmail());
      allow write: if isCeo() || isAdmin();
    }

    match /daily_archives/{archiveId} {
      allow read: if isAuthenticated() && canReadAllSalesData();
      allow create: if isCeo() || isAdmin();
      allow update: if isCeo() || isAdmin();
      allow delete: if isCeo();
    }

    match /daily_audit_logs/{logDate}/events/{eventId} {
      allow read: if isAuthenticated() && (isCeo() || isPrimaryCeo());
      allow create: if
        isAuthenticated() &&
        (isCeo() || isAdmin()) &&
        request.resource.data.get('actorEmail', '').lower() == currentUserEmail() &&
        request.resource.data.get('actorRole', '') in ['ceo', 'admin'];
      allow update, delete: if false;
    }

    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isCeo();
    }

    match /public/connectivity {
      allow read, write: if true;
    }

    match /test/connection {
      allow read, write: if true;
    }
  }
}
